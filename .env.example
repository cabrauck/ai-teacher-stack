TEACHER_TOOLS_HOST=0.0.0.0
TEACHER_TOOLS_PORT=8010
CURRICULUM_ROOT=/app/data/curriculum
VAULT_ROOT=/app/vault
EXPORT_ROOT=/app/exports
CLAUDE_OS_URL=http://claude-os:8051
CLAUDE_OS_INDEX_ROOT=/app/vault/Wiki
MEMORY_REQUIRE_PRIVACY_VALIDATION=true

# Optional local model endpoint
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Claude-OS core runtime
CLAUDE_OS_PROVIDER=local
CLAUDE_OS_RUN_WORKERS=true
CLAUDE_OS_BOOTSTRAP_WIKI_KB=true
CLAUDE_OS_BOOTSTRAP_SYNC=true
CLAUDE_OS_PROJECT_NAME=ai-teacher-stack
CLAUDE_OS_WIKI_KB_NAME=ai-teacher-stack-wiki
CLAUDE_OS_WIKI_MCP_TYPE=project_memories

# Disabled-by-default integrations
ENABLE_CLOUD_EXPORTS=false
ENABLE_STUDENT_DATA=false
