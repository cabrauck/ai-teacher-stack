#
# Host port bindings for the local runtime. The start script can move these to
# the next free local ports if the defaults are already in use.
HOST_LIBRECHAT_PORT=3080
HOST_TEACHER_TOOLS_PORT=8010
HOST_CLAUDE_OS_PORT=8051
HOST_CLAUDE_OS_FRONTEND_PORT=5173
STACK_PUBLIC_HOST=localhost

TEACHER_TOOLS_HOST=0.0.0.0
TEACHER_TOOLS_PORT=8010
CURRICULUM_ROOT=/app/data/curriculum
VAULT_ROOT=/app/vault
EXPORT_ROOT=/app/exports
CLAUDE_OS_URL=http://claude-os:8051
CLAUDE_OS_FRONTEND_URL=http://claude-os-frontend:5173
CLAUDE_OS_INDEX_ROOT=/app/vault/Wiki
LIBRECHAT_URL=http://librechat:3080
TEACHER_TOOLS_MCP_HOST=0.0.0.0
TEACHER_TOOLS_MCP_PORT=8020
MEMORY_REQUIRE_PRIVACY_VALIDATION=true

# LibreChat teacher frontend
HOST=localhost
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080
MONGO_URI=mongodb://librechat-mongodb:27017/LibreChat
APP_TITLE=ai-teacher-stack
ALLOW_REGISTRATION=true
ALLOW_EMAIL_LOGIN=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_PASSWORD_RESET=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=true
SEARCH=false

# LibreChat provider keys. Keep real values only in local .env.
OPENROUTER_KEY=
OPENAI_API_KEY=user_provided
ANTHROPIC_API_KEY=user_provided
GOOGLE_KEY=user_provided

# LibreChat local secrets. Replace in local .env before serious use.
CREDS_KEY=1111111111111111111111111111111111111111111111111111111111111111
CREDS_IV=22222222222222222222222222222222
JWT_SECRET=change-me-local-jwt-secret-before-serious-use
JWT_REFRESH_SECRET=change-me-local-refresh-secret-before-serious-use

# Optional local model endpoint
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Claude-OS core runtime
CLAUDE_OS_PROVIDER=local
CLAUDE_OS_RUN_WORKERS=true
CLAUDE_OS_BOOTSTRAP_WIKI_KB=true
CLAUDE_OS_BOOTSTRAP_SYNC=true
CLAUDE_OS_PROJECT_NAME=ai-teacher-stack
CLAUDE_OS_WIKI_KB_NAME=ai-teacher-stack-wiki
CLAUDE_OS_WIKI_MCP_TYPE=project_memories
ALLOWED_ORIGINS=http://localhost:3080,http://localhost:8051,http://localhost:5173,http://localhost:8010,http://127.0.0.1:3080,http://127.0.0.1:8051,http://127.0.0.1:5173,http://127.0.0.1:8010

# Disabled-by-default integrations
ENABLE_CLOUD_EXPORTS=false
ENABLE_STUDENT_DATA=false
